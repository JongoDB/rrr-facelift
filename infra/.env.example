# Docker Compose runtime config for the self-hosted stack.
# Copy to .env on the VM and fill in. Spec: planning/13-secrets-manifest.md.
#
# This file is also referenced by `pnpm infra:config` so `docker compose config`
# can validate the YAML without real values being present.

# Postgres
POSTGRES_USER=rrr
POSTGRES_PASSWORD=changeme-strong-random
POSTGRES_DB=rrr

# n8n
N8N_HOST=flows.triple-r-rv.com
N8N_WEBHOOK_URL=https://flows.triple-r-rv.com/
N8N_USER=admin
N8N_PASSWORD=changeme-strong-random
# IMPORTANT: never change after first run. Losing this loses encrypted credentials.
N8N_ENCRYPTION_KEY=changeme-32-plus-random-chars

# Speaches (Whisper STT)
# CPU defaults: medium.en + int8. GPU: large-v3 + float16.
WHISPER_MODEL=Systran/faster-whisper-medium.en
WHISPER_COMPUTE_TYPE=int8

# Cloudflare Tunnel
# Token from `cloudflared tunnel create` then routing config in CF dashboard.
CLOUDFLARE_TUNNEL_TOKEN=

# Misc
TIMEZONE=America/New_York
