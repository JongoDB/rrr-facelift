# Local-dev only. Cloudflare Workers Secrets are the production source of truth.
# See planning/13-secrets-manifest.md.

# Auth
JWT_SECRET=
APP_URL=http://localhost:5173
WEB_URL=http://localhost:4321

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5

# Zoho (Phase 01)
ZOHO_REFRESH_TOKEN=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_ORG_ID=
ZOHO_REGION=com

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@triple-r-rv.com
RESEND_REPLY_TO_EMAIL=info@triple-r-rv.com

# Twilio (Phase 02)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Business config — discovered from Zoho org detail (org_id 817532175).
SHOP_ADDRESS=255 Rock Hump Rd, Salisbury, NC
SHOP_LATITUDE=
SHOP_LONGITUDE=
OWNER_EMAIL=
AUTHORIZED_TECH_EMAILS=

# Shared secret on the Worker ↔ n8n boundary. n8n must send this in the
# X-RRR-API-Key header when calling /zoho/* or /agent/* endpoints.
RRR_INTERNAL_API_KEY=

# Database (Phase 02)
DATABASE_URL=postgresql://rrr:rrr@localhost:5432/rrr

# Geocoder
GEOCODER=nominatim
HERE_API_KEY=
