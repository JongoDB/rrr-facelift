# Repo-root .env.example
#
# Per-app/per-package .env.example files live alongside their package.json
# (apps/api/.env.example, apps/web/.env.example, infra/.env.example, etc.).
# This file holds variables shared across local dev when running multiple apps.

# Cloudflare account context (used by `wrangler` CLI when deploying)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# GitHub Actions CI uses GH Secrets, not this file. See .github/workflows/ci.yml.
