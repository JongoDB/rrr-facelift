{
  "name": "rrr-automation",
  "version": "0.0.0",
  "private": true,
  "description": "End-to-end automation platform for RRR Custom RV Services.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm -r --parallel --if-present dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r --if-present typecheck",
    "clean": "pnpm -r --if-present clean && rm -rf node_modules .turbo .vitest-cache coverage playwright-report",
    "infra:config": "docker compose -f infra/docker-compose.yml --env-file infra/.env.example config",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "zoho:mint": "node scripts/zoho-mint-refresh-token.mjs",
    "zoho:audit": "node scripts/zoho-audit.mjs",
    "sync:catalog": "tsx scripts/sync-zoho-catalog.ts",
    "prepare": "node -e \"console.log('rrr-automation workspace ready')\""
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@playwright/test": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
